/* components/privacy-modal/privacy-modal.wxss */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  pointer-events: auto;
}

.modal-container {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
  position: relative;
  max-height: 80vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.close-btn {
  position: absolute;
  right: 30rpx;
  top: 30rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #666;
  z-index: 10;
}

.modal-content {
  padding: 40rpx 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.agreement-list {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 30rpx;
  margin-bottom: 50rpx;
}

.agreement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.agreement-item:last-child {
  border-bottom: none;
}

.agreement-text {
  font-size: 30rpx;
  color: #007AFF;
}

.arrow {
  font-size: 36rpx;
  color: #999;
  transform: rotate(90deg);
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.button {
  flex: 1;
  height: 90rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: none;
  margin: 0;
  padding: 0;
}

.button::after {
  border: none;
}

.button-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.button-reject {
  background-color: #f0f0f0;
  color: #666;
}

.button-allow {
  background-color: #333;
  color: #fff;
}