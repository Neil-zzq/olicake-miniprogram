<view class="container">
  <!-- 地图在上方 -->
  <map 
    id="myMap"
    longitude="{{longitude}}"
    latitude="{{latitude}}" 
    scale="16"
    show-location
    bindregionchange="onMapMove"
    style="height: 300px;"
    animation="0" 
    duration="0"  
  >
    <!-- 地图中心标记点 -->
    <cover-view class="center-marker"></cover-view>
  </map>

  <!-- 中间搜索条 -->
  <view class="search-bar">
    <input 
      placeholder="搜索地址" 
      bindinput="onSearchInput"
      value="{{searchKeyword}}"
    />
  </view>

  <!-- POI列表 -->
  <scroll-view class="poi-list" scroll-y>
    <view 
      wx:for="{{poiList}}"
      wx:key="id"
      class="poi-item {{activeIndex === index ? 'active' : ''}}"
      bindtap="selectPoi"
      data-index="{{index}}"
    >
      <view class="title">{{item.title}}</view>
      <view class="address">{{item.address}}</view>
    </view>
  </scroll-view>

  <!-- 确认按钮 -->
  <view class="footer">
    <view class="confirm-btn" bindtap="confirmLocation">确认位置</view>
  </view>
</view>