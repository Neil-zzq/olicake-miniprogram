/* pages/add-address/map-choose/map-choose.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.map {
  width: 100%;
  height: 60vh;
}

.poi-list {
  flex: 1;
  background: white;
  padding: 20rpx;
}

.poi-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.poi-item.active {
  background: #f5f5f5;
}

.title {
  font-size: 30rpx;
  color: #333;
}

.address {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}

.footer {
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.confirm-btn {
  background: #07c160;
  color: white;
  text-align: center;
  padding: 25rpx;
  border-radius: 50rpx;
}