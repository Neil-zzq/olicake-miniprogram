.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 地图区域 - 固定高度 */
map {
  width: 100%;
  height: 300px; /* 固定高度，地图可见 */
}

/*中心标记点 */
.center-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 30rpx;
  height: 30rpx;
  background: #07c160;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  border: 4rpx solid white;
  box-shadow: 0 0 10rpx rgba(0,0,0,0.3);
}

/* 搜索条 */
.search-bar {
  padding: 20rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.search-bar input {
  background: #f5f5f5;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* POI列表 - 自适应高度 */
.poi-list {
  flex: 1;
  background: white;
  overflow-y: auto;
}

.poi-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.poi-item.active {
  background: #f5f5f5;
}

.title {
  font-size: 30rpx;
  color: #333;
}

.address {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}

.footer {
  padding: 20rpx;
  color: white;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.confirm-btn {
  background: #07c160;
  color: white;
  text-align: center;
  padding: 25rpx;
  border-radius: 50rpx;
}