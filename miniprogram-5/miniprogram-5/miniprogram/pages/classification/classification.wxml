<!--pages/classification/classification.wxml-->
<view class="page-ios">
  <!-- iOS 风格：圆形按钮导航栏（像参考图） -->
  <view class="nav-spacer" style="height: {{navBarHeight}}px;"></view>

  <!-- 标题 + 右侧动作按钮 -->
  <view class="header">
    <view class="header-row">
      <text class="header-title">Discover products</text>
      <view class="header-actions">
        <view class="action-circle" bindtap="onSearchTap">
          <text class="action-icon">⌕</text>
        </view>
        <view class="action-circle" bindtap="onFilterTap">
          <text class="action-icon">⚙</text>
        </view>
      </view>
    </view>

    <!-- 上方类目胶囊（横向滚动） -->
    <scroll-view class="chips" scroll-x="true" show-scrollbar="false" enhanced="true">
      <view class="chips-inner">
        <view class="chip {{activeTab === index ? 'chip--active' : ''}}" wx:for="{{vtabs}}" wx:for-item="tab" wx:for-index="index" wx:key="title" data-index="{{index}}" bindtap="onChipTap">
          <text class="chip-text">{{tab.title}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 商品卡片两列 -->
  <view class="grid">
    <navigator class="card" hover-class="card-hover" hover-stay-time="120" wx:for="{{activeList}}" wx:for-item="spu" wx:key="id" url="/pages/detail/detail?id={{spu.id}}">
      <view class="card-top">

      </view>
      <view class="img-wrap">
        <image class="card-img" src="{{spu.cover}}" mode="aspectFit" />
      </view>
      <view class="card-body">
        <view>
          <text class="card-title">{{spu.title}}</text>
          <text class="card-price">￥{{spu.pricemin}}</text>
        </view>
        <view>
          <view class="go-circle">
            <image src="../../img/倾斜箭头.png" mode="widthFix" class="go-icon"/>
          </view>
        </view>

      </view>
    </navigator>
  </view>
</view>