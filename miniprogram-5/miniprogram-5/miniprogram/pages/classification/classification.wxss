/* pages/classification/classification.wxss (iOS 风格) */
page {
  width: 100%;
  min-height: 100%;
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
    "Helvetica Neue", sans-serif;
}

.page-ios {
  min-height: 100%;
  box-sizing: border-box;
  padding: 0 28rpx 56rpx;
}

/* 顶部导航栏（圆形按钮风格） */
.ios-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: rgba(245, 245, 247, 0.96);
}

.ios-nav__row {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  gap: 14rpx;
}

.nav-fill {
  flex: 1;
}

.nav-spacer {
  width: 100%;
}

.nav-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-circle__icon {
  font-size: 38rpx;
  color: #111111;
  transform: translateY(-2rpx);
}

.nav-circle__img {
  width: 34rpx;
  height: 34rpx;
}

.nav-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 标题区 */
.header {
  padding-top: 22rpx;
  position: relative;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 46rpx;
  font-weight: 750;
  color: #111111;
}

.header-actions {
  display: flex;
  gap: 14rpx;
}

.action-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 34rpx;
  color: #111111;
}

/* 类目胶囊 */
.chips {
  margin-top: 22rpx;
  width: 100%;
}

.chips-inner {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 2rpx;
}

.chip {
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background-color: #ffffff;
  color: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.chip--active {
  background-color:#f5e9b6;
}

.chip-text {
  font-size: 26rpx;
  font-weight: 650;
  white-space: nowrap;
}

.chip--active .chip-text {
  color: #111111;
}

/* 商品卡片网格 */
.grid {
  margin-top: 26rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: 48%;
  background-color: #ffffff;
  border-radius: 34rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin-bottom: 26rpx;
   /* 新增：让动画更顺滑 */
   transition: transform 160ms ease, box-shadow 160ms ease;
}

.card-top {
  padding: 18rpx 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.card-hover {
  animation: card-bounce 180ms ease;
}

@keyframes card-bounce {
  0% {
    transform: translateY(0) scale(1);
    box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  }
  60% {
    transform: translateY(-10rpx) scale(1.02);
    box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.12);
  }
  100% {
    transform: translateY(0) scale(1);
    box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  }
}
.dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background-color: #e5e5ea;
}

.dot--on {
  background-color: #111111;
}

.go-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background-color: #f5e9b6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.go-icon {
  height: 40rpx;
  width: 40rpx;
}

.img-wrap {
  margin: 14rpx 18rpx 0;
  border-radius: 28rpx;
  background-color: #f7f7fa;
  overflow: hidden;
  position: relative;
}

.card-img {
  width: 100%;
  height: 300rpx;
  display: block;
}

.card-body {
  padding: 22rpx 30rpx 22rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 650;
  color: #111111;
  line-height: 1.4;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.card-price {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 650;
  color: #111111;
}

/* 奶油搅拌动态图标 */
.cream-stir {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fffaf4, #fff3e0);
  box-shadow: 0 4rpx 14rpx rgba(220, 160, 80, 0.18), inset 0 2rpx 6rpx rgba(255, 220, 160, 0.3);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cream-ring {
  position: absolute;
  border-radius: 50%;
  border-style: solid;
  border-color: transparent;
}

.cream-ring-outer {
  width: 36rpx;
  height: 36rpx;
  border-width: 4rpx;
  border-top-color: rgba(230, 170, 100, 0.75);
  border-right-color: rgba(230, 170, 100, 0.45);
  animation: cream-spin-cw 1.4s linear infinite;
}

.cream-ring-mid {
  width: 22rpx;
  height: 22rpx;
  border-width: 3rpx;
  border-bottom-color: rgba(240, 190, 120, 0.8);
  border-left-color: rgba(240, 190, 120, 0.5);
  animation: cream-spin-ccw 1s linear infinite;
}

.cream-swirl-arc {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
  border-top-color: rgba(255, 200, 120, 0.9);
  animation: cream-spin-cw 0.7s linear infinite;
}

.cream-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #ffdda0, #f5c07a);
  box-shadow: 0 0 4rpx rgba(240, 180, 80, 0.5);
  animation: cream-pulse 1.3s ease-in-out infinite;
}

@keyframes cream-spin-cw {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes cream-spin-ccw {
  from { transform: rotate(0deg); }
  to   { transform: rotate(-360deg); }
}

@keyframes cream-pulse {
  0%, 100% { transform: scale(1);   opacity: 0.7; }
  50%       { transform: scale(1.5); opacity: 1; }
}

/* ======== 排序按钮（与 action-circle 同大小，始终白底） ======== */
.sort-icon-img {
  width: 38rpx;
  height: 38rpx;
}

/* ======== 布局切换图标 ======== */
.layout-icon {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  width: 34rpx;
  height: 34rpx;
  justify-content: center;
}

.li-row {
  display: flex;
  gap: 5rpx;
}

.li-cell {
  flex: 1;
  height: 12rpx;
  border-radius: 3rpx;
  background-color: #111111;
}

/* 列表模式：宽单行 */
.li-row--wide {
  display: flex;
}

.li-row--wide::after {
  content: '';
  flex: 1;
  height: 8rpx;
  border-radius: 3rpx;
  background-color: #111111;
}

/* 列表模式下，隐藏 2x2 格子行 */
.layout-icon--list .li-row:not(.li-row--wide) {
  display: none;
}

/* 网格模式下，隐藏宽行 */
.layout-icon--grid .li-row--wide {
  display: none;
}

/* ======== 列表模式：grid 覆盖 ======== */
.grid--list {
  flex-direction: column;
}

.card--list {
  width: 100%;
  margin-bottom: 28rpx;
  height: 700rpx;
}

/* 列表模式图片：更高，无外边距圆角 */
.card--list .img-wrap {
  margin: 0;
  border-radius: 0;
  border-top-left-radius: 34rpx;
  border-top-right-radius: 34rpx;
  position: relative;
  height: 530rpx;
}

.card--list .card-img {
  height: 530rpx;
}

/* 图片右上角收藏按钮 */
.img-heart {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.heart-icon {
  font-size: 32rpx;
  color: #e57373;
}

.heart-icon--filled {
  color: #e53935;
}

/* 列表模式 card-body */
.card--list .card-body {
  padding: 20rpx 32rpx 20rpx;
  align-items: center;
}

.card--list .card-info {
  flex: 1;
  min-width: 0;
}

/* 副标题（列表模式显示） */
.card-sub {
  display: block;
  font-size: 22rpx;
  color: #aaaaaa;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

/* 列表模式字体放大 */
.card--list .card-title {
  font-size: 36rpx;
  font-weight: 700;
  white-space: normal;
}

.card--list .card-price {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 5rpx;
}

/* 列表模式 go-circle 改为深色 */
.card--list .go-circle {
  width: 76rpx;
  height: 76rpx;
  background-color: #f5e9b6;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.card--list .go-icon {
  width: 40rpx;
  height: 40rpx;
  filter: invert(1);
}

/* card-info 在 grid 模式下不需要额外样式 */
.card-info {
  flex: 1;
  min-width: 0;
}