<!--pages/detail/detail.wxml-->
<view class="page-ios" wx:if="{{cakeitems && cakeitems.img && cakeitems.img.length > 0}}">
  <!-- iOS 风格自定义导航栏（更薄、标题靠左） -->
  <view class="ios-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="ios-nav__row" style="height: {{navBarContentHeight}}px;">
      <view class="nav-left" bindtap="goback">
        <text class="nav-back">‹</text>
      </view>
      <text class="nav-title">详情</text>
      <button open-type="share" class="nav-action" size="mini">
        <image class="nav-action__icon" src="cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/分享.png" mode="widthFix" />
      </button>
    </view>
  </view>
  <view class="nav-spacer" style="height: {{navBarHeight}}px;"></view>

  <!-- 大图轮播：完整展示优先 -->
  <swiper class="hero-swiper" indicator-dots="true" autoplay="true" interval="5000" duration="350">
    <swiper-item class="hero-item" wx:for="{{cakeitems.img}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFit" class="hero-img" />
    </swiper-item>
  </swiper>

  <view class="content">
    <!-- 商品信息卡片 -->
    <view class="card product-card">
      <text class="price-range">￥{{cakeitems.pricemin}}-{{cakeitems.pricemax}}</text>
      <text class="product-name">{{cakeitems.title}}</text>
      <text class="product-sub">精选用料 · 当日制作</text>
    </view>

    <!-- iOS cell 列表 -->
    <view class="card cell-list">
      <view class="cell" bindtap="popupTips">
        <text class="cell-title">服务</text>
        <view class="cell-right">
          <text class="cell-desc">到店自提 / 同城配送</text>
          <text class="chevron">›</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="cell" bindtap="showTan">
        <text class="cell-title">选择</text>
        <view class="cell-right">
          <text class="cell-desc">尺寸 / 口味 / 保温袋</text>
          <text class="chevron">›</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 底部固定操作条 -->
<view class="bottom-bar">
  <view class="cart-entry" catchtap="goToShoppingCart">
    <view class="cart-icon-wrap">
      <image class="cart-icon" src="cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/购物车2.png" mode="widthFix" />
      <view class="badge" wx:if="{{cart && cart.length > 0}}">{{cart.length}}</view>
    </view>
    <text class="cart-text">购物车</text>
  </view>
  <view class="primary-btn" bindtap="showTan">加入购物车</view>
</view>
<page-container show="{{tipsShow}}" round="true"> 
  <view class="tips">
    <view class="tips-title">到店自提</view>
    <view class="tips-content">
      <view class="tips-content">
        <view>深圳市南头街道红花园社区51号</view>
        <view class="tips-distance">距离{{currentDistance}}km</view>
      </view>

      <map id="shop-map" style="width: 100%; height: 300px;" latitude="{{latitude}}" longitude="{{longitude}}" markers="{{markers}}" covers="{{covers}}" show-location></map>

    </view>
    <view class="tips-title">同城配送</view>
    <view class="tips-content">可选择同城配送并预约送达时间，本商品运费：最低0.00元起送，运费￥0.00起</view>
    <button class="tips-button" bindtap="tipsButton">我知道了</button>
  </view>
</page-container>
<view class="tan-bg" wx:if="{{inShow==true}}">
  <view class="tan-block">
    <view class="sheet-handle"></view>
    <view class="tan-block-title">
      <view>
        <image src="{{cakeitems.cover}}" class="tan-img" />
      </view>
      <view class="tan-detail">
        <view class="price">￥{{Price}}</view>
        <view>请选择 {{Size}} {{Taste}} {{Bag}}</view>
      </view>
      <view class="tan-close" bindtap="showTan">×</view> 
    </view>
    <view class="tan-block-size">
      <view>尺寸 </view>
      <view class="tan-size">
        <view  wx:for="{{cakeitems.cakeSize}}" wx:key="index" class="tan-size-choose"  >
           <view bindtap="cakesizeChoosed"data-index="{{index}}" class="tan-size-choosed" wx:if="{{selectedSizeIndex === index}}">{{item.size}}</view>
           <view bindtap="cakesizeChoosed" data-index="{{index}}" wx:else>{{item.size}}</view>
        </view>
      </view>
    </view>
    <view class="tan-block-taste">
      <view>口味</view>
      <view class="tan-taste">
        <view wx:for="{{cakeitems.cakeTaste}}" wx:key="index" class="tan-taste-choose">
           <view  bindtap="caketasteChoosed" wx:if="{{selectedTasteIndex === index}}"    class="tan-taste-choosed" data-index="{{index}}" >{{item}}</view>
           <view  bindtap="caketasteChoosed" wx:else   data-index="{{index}}" >{{item}}</view>
        </view>
      </view>

    </view>
    <view class="tan-block-bag">
      <view>保温袋</view>
      <view class="tan-bag">
        <view wx:for="{{cakeBag}}" wx:key="index" class="tan-bag-choose" data-index="{{index}}">
          <view bindtap="cakebagChoose" class="tan-bag-choosed" wx:if="{{selectedBagIndex === index}}"data-index="{{index}}">{{item.name}}</view>
          <view bindtap="cakebagChoose" wx:else  data-index="{{index}}">{{item.name}}</view>
        </view>
      </view>
    </view>
    <view class="tan-block-amount">
      <view class="mod">
        <view class="amount">数量</view>
        <view class="selector">
          <view bindtap="subnum">-</view>
          <input class="num" value="{{num}}" />
          <view bindtap="addnum">+</view>
        </view>
      </view>
    </view>
    <view class="input">
      <view class="input-title">订购人电话</view>
      <input class="input-content" type="text" placeholder="请填写手机号" bindinput="bindPhoneInput" value="{{phone}}"	type="number"/>
      <view class="input-title">祝福语</view>
      <input class="input-content" type="text" placeholder="请填写留言（8个字以内）"bindinput="bindMessageInput" value="{{message}}" />
    </view>
    <view class="shopping-cart" bindtap="onAddcart">加入购物车</view>
  </view>
</view>