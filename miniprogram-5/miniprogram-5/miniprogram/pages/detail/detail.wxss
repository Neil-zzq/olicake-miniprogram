/* pages/detail/detail.wxss (iOS 风格) */
page {
  width: 100%;
  min-height: 100%;
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
    "Helvetica Neue", sans-serif;
}

.page-ios {
  min-height: 100%;
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* iOS 风格自定义导航栏 */
.ios-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: rgba(245, 245, 247, 0.96);
}

.ios-nav__row {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.nav-left {
  width: 120rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-back {
  font-size: 56rpx;
  line-height: 1;
  color: #111111;
  transform: translateY(-2rpx);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 650;
  color: #111111;
}

.nav-action {
  width: 120rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0;
  margin: 0;
  background: transparent;
}

.nav-action::after {
  border: none;
}

.nav-action__icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-spacer {
  width: 100%;
}

/* 轮播大图：完整展示优先（aspectFit） */
.hero-swiper,
.hero-item {
  height: 62vh;
  max-height: 880rpx;
  min-height: 640rpx;
  background-color: #ffffff;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.content {
  padding: 14rpx 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 商品信息卡片 */
.product-card {
  padding: 18rpx 20rpx 20rpx;
}

.price-range {
  display: block;
  font-size: 40rpx;
  font-weight: 750;
  color: #111111;
  letter-spacing: 0.5rpx;
}

.product-name {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 650;
  color: #111111;
  line-height: 1.35;
}

.product-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

/* iOS cell 列表 */
.cell-list {
  margin-top: 14rpx;
}

.cell {
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cell-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.cell-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cell-desc {
  font-size: 26rpx;
  color: #8e8e93;
}

.chevron {
  font-size: 36rpx;
  color: #c7c7cc;
}

.divider {
  height: 2rpx;
  background-color: #f2f2f7;
  margin-left: 20rpx;
}

/* 底部固定操作条（iOS 风格） */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 15;
  height: 108rpx;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background-color: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid #f2f2f7;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-entry {
  width: 140rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cart-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
}

.cart-icon {
  width: 56rpx;
  height: 56rpx;
}

.badge {
  position: absolute;
  top: -10rpx;
  right: -12rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cart-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.primary-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  background-color: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 650;
}

/* tips 弹层 */
.tips {
  margin: 30rpx;
  font-size: 30rpx;
  line-height: 150%;
}

.tips-title {
  font-size: 30rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.tips-content {
  color: #8e8e93;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.tips-button {
  background-color: #111111;
  color: #ffffff;
  width: 100%;
  border-radius: 20rpx;
}

/* 规格选择底部弹层（保留你原逻辑，换成 iOS sheet 视觉） */
.tan-bg {
  position: fixed;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 20;
}

.tan-block {
  position: fixed;
  width: 100%;
  height: 78vh;
  max-height: 1400rpx;
  background-color: #ffffff;
  z-index: 21;
  bottom: 0;
  font-size: 30rpx;
  line-height: 150%;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
}

.sheet-handle {
  width: 80rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background-color: #e5e5ea;
  margin: 14rpx auto 0;
}

.tan-img {
  height: 230rpx;
  width: 230rpx;
  border-radius: 20rpx;
}

.tan-block-title {
  display: flex;
  position: relative;
  margin: 24rpx;
  font-weight: 550;
}

.tan-detail {
  text-align: center;
  width: 500rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.tan-detail .price {
  font-size: 40rpx;
  font-weight: 750;
  color: #111111;
}

.tan-close {
  position: relative;
  font-size: 42rpx;
  bottom: 10rpx;
  color: #8e8e93;
}

.tan-size,
.tan-taste,
.tan-bag {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
}

.tan-size-choose,
.tan-taste-choose,
.tan-bag-choose {
  width: 220rpx;
  height: 60rpx;
  background-color: #f2f2f7;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 10rpx;
  margin-top: 10rpx;
  border-radius: 18rpx;
}

.tan-size-choosed,
.tan-taste-choosed,
.tan-bag-choosed {
  background-color: #111111;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  border-radius: 18rpx;
}

.tan-block-size,
.tan-block-taste,
.tan-block-bag,
.tan-block-amount {
  margin: 10rpx 24rpx;
}

.mod {
  display: flex;
  justify-content: space-between;
}

.selector {
  display: flex;
  font-size: 30rpx;
  width: 170rpx;
  justify-content: space-between;
}

.selector view {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background-color: #f2f2f7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.num {
  width: 70rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background-color: #f2f2f7;
  text-align: center;
}

.input {
  margin: 18rpx 24rpx 0;
  display: flex;
  flex-wrap: wrap;
}

.input-title {
  width: 200rpx;
  margin: 0 20rpx 20rpx 0;
  color: #111111;
  font-weight: 600;
}

.input-content {
  width: 420rpx;
  background-color: #f2f2f7;
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  box-sizing: border-box;
}

.shopping-cart {
  font-size: 30rpx;
  background-color: #111111;
  color: #ffffff;
  text-align: center;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 48rpx);
  border-radius: 22rpx;
  margin: 24rpx;
}
