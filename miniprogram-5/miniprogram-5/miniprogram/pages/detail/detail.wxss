/* pages/detail/detail.wxss */
page{
  height:1355rpx;
}
.pagecontent{
  height: 1265rpx;
}

.detail{
  display:flex;
  align-content:space-between;
  justify-content: space-between;
  height: 120rpx;
  
}
.box{
  display:flex;
  flex-direction:column;
  justify-content: center;
  margin: 10rpx 0 0 50rpx;
  
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
.price{
  font-size:45rpx;
  font-weight:700;
}
.name{
  text-align: center;
  font-size: 35rpx;
  font-weight:600;
}
.share-button{
  height: 170rpx;
  width: 130rpx;
  margin:10rpx;
  padding: 0%;
  background-color: rgb(255, 255, 255);
}
.share-button image{
  height: 60rpx;
  width: 60rpx;
}

.service-choose{
  display: flex;
  font-size: 30rpx;
  justify-content: space-between;
  flex-direction:row;
  height: 130rpx;
  background-color: rgb(255, 255, 255);
  margin-bottom: 10rpx;
  margin-top:10rpx;
  
}
.content{
  position: relative;
  right: 52rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.arrow{
  position: relative;
  right: 32rpx;
  
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #999;
}
.title{
  position: relative;
  left:30rpx;
  
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #999;
}
.yunfei{
  background-color: rgb(255, 255, 255);
  height: 90rpx;
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  font-size: 30rpx;
}
.yunfei-title{
  color: #999;
  position: relative;
  left: 30rpx;
}
.yunfei-content{
  position: relative;
  left: 70rpx;
}
.title,.content,.arrow{
  height: 130rpx;
  justify-content: space-around;
}
.detail2{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 150rpx;
  background-color: rgba(238, 238, 238, 0.918);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
.tips{
  margin: 30rpx;
  font-size: 30rpx;
  line-height:150%;
}
.tips-title{
  font-size: 30rpx;
  margin-top: 10rpx;
  margin-bottom:10rpx ;
}
.tips-content{
  color: #999;
  margin-top: 10rpx;
  margin-bottom:10rpx ;
}
.tips-button{
  background-color: rgb(58, 57, 57);
  color: rgb(255, 255, 255);
  width: 100%;
  border-radius: 20rpx;
}
.tan-bg{
  position: fixed;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index:0;
}
.tan-block{
  position: fixed;
  width: 100%;
  height: 1100rpx;
  background-color:#fff;
  z-index:999;
  bottom: 0;
  font-size: 30rpx;
  line-height: 150%;
  font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
.tan-img{
  
  height: 230rpx;
  width: 230rpx;
  border-radius: 20rpx;
}
.tan-block-title{
  display: flex;
  position: relative;
  margin: 30rpx;
  font-weight: 550;
}
.tan-detail{
  text-align: center;
  width: 500rpx;
  display: flex;
  flex-direction: column;
  justify-content:flex-end;
}
.tan-close{
  position: relative;
  font-size: 35rpx;
  bottom: 20rpx;
  color: #999;
}
.tan-size,.tan-taste,.tan-bag{
  display: flex;
  justify-content:flex-start;
  flex-wrap: wrap;
}
.tan-size-choose,.tan-taste-choose,.tan-bag-choose{
  width: 220rpx;
  height: 60rpx;
  background-color: rgba(243, 238, 238, 0.973);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 10rpx;
  margin-top:10rpx; 
  border-radius: 20rpx;
  
}

.tan-size-choosed,.tan-taste-choosed,.tan-bag-choosed{
  background-color: rgb(61, 60, 60);
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: rgb(255, 255, 255);
  border-radius: 20rpx;
}
.tan-block-size,.tan-block-taste,.tan-block-bag,.tan-block-amount{
  margin: 10rpx;
  margin-left: 30rpx;
}
.mod{
  display: flex;
  justify-content: space-between;
}
.selector{
  display: flex;
  font-size: 30rpx;
  width: 150rpx;
  justify-content: space-between;
}
.selector view{
  width: 30rpx;
  background-color: rgba(243, 238, 238, 0.973);
}
.num{
  width: 60rpx;
  background-color: rgba(243, 238, 238, 0.973);
  text-align: center;
}
.input{
  margin: 30rpx  0  0  30rpx;
  display: flex;
  flex-wrap: wrap;
  
}
.input-title{
  width: 200rpx;
  margin: 0 20rpx 20rpx 0 ;
}
.input-content{
  width: 400rpx;
}
.selector{
  text-align:center
}

.shopping-cart{
  font-size: 30rpx;
  background-color: rgb(61, 60, 60);
  color: #fff;
  text-align:center;
  height:100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 600rpx;
  border-radius: 30rpx;
  position: relative;
  left: 70rpx;

  
}
.tan-block-amount{
  margin-right: 40rpx;
}

.swiperimg{
  height: 100%;
  width: 100%;
}
.swiperitem,.swiperbox{
  height: 1000rpx;
}
.cart image{
  height: 60rpx;
  width: 60rpx;
}
.bottom{
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
  position: fixed;
  bottom: 0rpx;
  width: 100%;
}
.cart,.addcart{
  width: 50%;
  text-align: center;
  height:100rpx ;
}

.cart{
  display: flex;
  flex-direction: column;
  justify-items: center;
  align-items: center;
  justify-content:center;
  
}

.addcart{
  background-color: rgb(51, 50, 56);
  
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgb(255, 255, 255);
}
.sup{
  border-radius: 50%;
  border: 5rpx  solid  rgb(94, 93, 93);
  height: 18rpx;
  width: 18rpx;
  position: relative;
  left:48rpx;
  bottom:70rpx;
  color:rgb(56, 55, 55);
  font-size:22rpx ;
  font-weight: 1000;
  line-height: 20rpx;
}
.cart-icon{
  height:50rpx
}