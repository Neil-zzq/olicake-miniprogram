/* pages/favorites/favorites.wxss */
page {
  width: 100%;
  min-height: 100%;
  background-color: #f8f0ce;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
}

.page-ios {
  min-height: 100%;
  box-sizing: border-box;
}

.nav-spacer {
  width: 100%;
}

/* 自定义导航栏 */
.ios-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: rgba(248, 240, 206, 0.96);
}

.ios-nav__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-back {
  width: 80rpx;
  font-size: 44rpx;
  font-weight: 400;
  color: #111111;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111111;
}

.nav-placeholder {
  width: 80rpx;
}

/* 内容区 */
.content {
  padding: 24rpx 28rpx 56rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-heart {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff5f5, #ffe8e8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #e57373;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 56rpx;
}

.empty-btn {
  padding: 24rpx 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f5e9b6, #e8d890);
  font-size: 28rpx;
  font-weight: 600;
  color: #3a3530;
}

/* 卡片网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: 48%;
  background-color: #ffffff;
  border-radius: 34rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin-bottom: 26rpx;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.card-hover {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.12);
}

.card-link {
  display: block;
  text-decoration: none;
}

.img-wrap {
  margin: 14rpx 18rpx 0;
  border-radius: 28rpx;
  background-color: #f7f7fa;
  overflow: hidden;
  position: relative;
}

.card-img {
  width: 100%;
  height: 300rpx;
  display: block;
}

.img-heart {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.heart-icon {
  font-size: 32rpx;
  color: #e57373;
}

.heart-icon--filled {
  color: #e53935;
}

.card-body {
  padding: 22rpx 30rpx 22rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 650;
  color: #111111;
  line-height: 1.4;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.card-price {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 650;
  color: #111111;
}

.go-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background-color: #f5e9b6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.go-icon {
  width: 40rpx;
  height: 40rpx;
}
