/* pages/home/home.wxss */
.homepage{
  width: 100%;
  height: 1000rpx;
}

.imgItem ,.slide-image{
  width: 100%;
  height:100%;
}
.block{
  height:300rpx;
  display: flex;
  justify-content:space-around;
  align-items:center;
}
.cake,.tea,.others {
  height:100rpx;
  width: 30%;
  background-color: rgb(211, 197, 179);
  text-align:center;
  border-radius:10px;
}
.cake,.tea,.others text{
  color: rgb(252, 250, 250);
  align-items:center;
  justify-content:center;
}

.block image{
  width: 30%;
  height: 30%;
  border-radius:10px;
}
.rechargeicon,.vipicon{
  height:120rpx;
  width:60rpx;
  font-size:80rpx;
  font-weight: 900;
  color: rgb(51, 85, 52);
  display: flex;
  align-items:flex-end;
  

}
.vipicon{
  height:120rpx;
  width:120rpx;
}
.recharge,.vip{
  display: flex;
  background-color: rgb(143, 184, 157);
  width: 50%;
  height:120rpx;
  justify-content: space-evenly;
}
.recharge-vip{
  display: flex;
}
.rechargefont,.vipfont{
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.vip{
  background-color: #f5d9dd;
} 
.addCs-info image{
    width: 100rpx;
    border: 3rpx solid rgb(250, 250, 250);
    border-radius: 20rpx;
}
.addCs-info-font{
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  margin-left: 10rpx;
  font-size: 25rpx;
  font-weight: 500;
}
.addCs-info{
  display: flex;
}
.addCs{
  display: flex;
  justify-content: space-between;
  margin: 40rpx;
  align-items: center;
  
}
.addCs-info-font-two{
  color:#999;
}
.addCs-btn{
  background-color: rgb(13, 13, 14);
  color: rgb(255, 255, 255);
  width: 120rpx;
  height: 60rpx;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 30rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
}
.tips{
  background-color: rgb(228, 226, 226);
  border-radius: 20rpx;
  height: 370rpx;
  margin: 0 20rpx 0 20rpx;
}
.title{
  color: rgb(25, 51, 25);
  text-align: center;
  padding-top: 40rpx;
  font-weight: 600;
  font-size: 32rpx;
}
.time{
  font-weight: 600;
  text-align: center;
  font-size: 35rpx;
  margin: 30rpx 0rpx 10rpx 0rpx ;
}
.content{
  font-size: 20rpx;
  text-align: center;
  line-height: 30rpx;
  font-weight: 500;
}