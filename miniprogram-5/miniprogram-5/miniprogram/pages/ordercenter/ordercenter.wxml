<!--pages/ordercenter/ordercenter.wxml - iOS 风格 -->
<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <icon type="search" size="16" class="search-icon" />
    <input type="text" placeholder="搜索订单信息" class="search-input" placeholder-class="search-placeholder" />
  </view>

  <!-- Tab: Segmented Control -->
  <view class="segment-control">
    <view
      class="segment {{currentTab === 0 ? 'segment--active' : ''}}"
      bindtap="switchTab"
      data-tab="0"
    >
      <text>当前订单</text>
    </view>
    <view
      class="segment {{currentTab === 1 ? 'segment--active' : ''}}"
      bindtap="switchTab"
      data-tab="1"
    >
      <text>历史订单</text>
    </view>
  </view>

  <!-- 当前订单列表 -->
  <scroll-view wx:if="{{currentTab === 0}}" class="content" scroll-y>
    <view class="section">
      <view
        class="order-card"
        wx:for="{{orders}}"
        wx:key="orderNo"
        wx:for-item="order"
      >
        <navigator class="order-inner" url="/pages/orderdetail/orderdetail?id={{order.orderNo}}">
          <view class="order-header">
            <text class="order-time">{{order.displayPayTime}}</text>
            <text class="order-status">已支付</text>
          </view>
          <view class="order-gallery">
            <view class="gallery-imgs">
              <image
                wx:for="{{order.productInfo}}"
                wx:key="*this"
                wx:for-item="img"
                class="gallery-img"
                src="{{img.cover}}"
                mode="aspectFill"
              />
            </view>
            <text class="gallery-count">共{{order.productInfo.length}}件</text>
          </view>
          <view class="order-footer">
            <view class="order-total">
              <text class="total-label">合计 </text>
              <text class="total-price">¥{{order.totalFee / 100}}</text>
            </view>
            <text class="order-delivery">含运费 ¥{{order.customerInfo.deliveryfee}}</text>
          </view>
        </navigator>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{orders.length === 0 && !isLoading}}">
      <text>暂无当前订单</text>
    </view>
  </scroll-view>

  <!-- 历史订单列表 -->
  <scroll-view wx:if="{{currentTab === 1}}" class="content" scroll-y>
    <view class="section">
      <view
        class="order-card"
        wx:for="{{ordersCompleted}}"
        wx:key="orderNo"
        wx:for-item="order"
      >
        <navigator class="order-inner" url="/pages/orderdetail/orderdetail?id={{order.orderNo}}">
          <view class="order-header">
            <text class="order-time">{{order.displayPayTime}}</text>
            <text class="order-status order-status--muted">{{order.statusText}}</text>
          </view>
          <view class="order-gallery">
            <view class="gallery-imgs">
              <image
                wx:for="{{order.productInfo}}"
                wx:key="*this"
                wx:for-item="img"
                class="gallery-img"
                src="{{img.cover}}"
                mode="aspectFill"
              />
            </view>
            <text class="gallery-count">共{{order.productInfo.length}}件</text>
          </view>
          <view class="order-footer">
            <view class="order-total">
              <text class="total-label">合计 </text>
              <text class="total-price">¥{{order.totalFee / 100}}</text>
            </view>
            <text class="order-delivery">含运费 ¥{{order.customerInfo.deliveryfee}}</text>
          </view>
        </navigator>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{ordersCompleted.length === 0 && !isLoading}}">
      <text>暂无历史订单</text>
    </view>
  </scroll-view>
</view>
