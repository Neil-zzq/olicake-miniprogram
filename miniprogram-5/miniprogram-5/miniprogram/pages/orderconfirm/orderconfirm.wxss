.time-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.time-picker-content {
  background: #fff;
  width: 85%;
  border-radius: 16rpx;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 50rpx;
  color: #999;
}

.picker-body {
  display: flex;
  height: 500rpx;
}

.date-list {
  width: 35%;
  background: #f5f5f5;
}

.date-item {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.date-item.active {
  background: #fff;
  color: black;
  font-weight: bold;
}

.time-list {
  width: 65%;
}

.time-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  
}

.time-item.active {
  color: black;
  font-weight: bold;
}

.picker-footer {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.confirm-btn {
  background: black;
  color: #fff;
  text-align: center;
  padding: 20rpx;
  border-radius: 50rpx;
}
/* 地址弹窗样式 */
.address-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
}

.mask {
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.address-content {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 100vh;
}

.address-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.address-list {
 
  max-height: 60vh;
}

.address-item {
  margin: 20rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  width: 95%;
  justify-content: space-between;
  align-items: center;
  height: 150rpx;
}

.default {
  background: #f5f5f5;
}

.default-badge {
  background: #07c160;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.footer {
  padding: 32rpx;
  background: #fff;
}

.add-btn {
  background: black;
  color: white;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
}
.chooseicon{
  width: 35rpx;
}
.editicon{
  height: 45rpx;
  width: 45rpx;
}
.name2,.phone2{
  font-size: 28rpx;
  color: #999;
}
.addressInfo{
  width: 85%;
}

/* ======== 会员折扣行 ======== */
.discount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.discount-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.discount-tag {
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #c9a227, #e8c050);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.discount-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #e74c3c;
}

/* ======== 代金券行 ======== */
.coupon {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.coupon-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.coupon-count {
  font-size: 22rpx;
  color: #e74c3c;
  background-color: #fef0f0;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.coupon-right {
  display: flex;
  align-items: center;
}

.coupon-selected {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.coupon-deduct {
  font-size: 28rpx;
  font-weight: 600;
  color: #e74c3c;
}

.coupon-remove {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
}

.coupon-available {
  font-size: 26rpx;
  color: #c9a227;
  font-weight: 600;
}

.coupon-none {
  font-size: 26rpx;
  color: #999;
}

/* ======== 代金券选择弹窗内容 ======== */
.voucher-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

.voucher-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background-color: #fff8ee;
  border: 1.5rpx solid #e8c050;
}

.voucher-selected {
  background-color: #fff3cd;
  border-color: #c9a227;
}

.voucher-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  flex-shrink: 0;
  border-right: 1.5rpx dashed #e8c050;
  padding-right: 20rpx;
  margin-right: 20rpx;
}

.voucher-amount {
  font-size: 44rpx;
  font-weight: 750;
  color: #c9a227;
}

.voucher-min {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.voucher-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.voucher-desc {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.voucher-expire {
  font-size: 22rpx;
  color: #aaa;
}