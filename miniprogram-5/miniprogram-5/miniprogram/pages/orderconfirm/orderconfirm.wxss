/* pages/orderconfirm/orderconfirm.wxss - iOS 原生风格 */

page {
  background-color: #f2f2f7;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Helvetica Neue", sans-serif;
}

/* ======== 主滚动区 ======== */
.page-scroll {
  height: calc(100vh - 120rpx);
}

.page-content {
  padding: 24rpx 28rpx 140rpx;
  min-height: 100%;
}

/* ======== 分组区块 ======== */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8e8e93;
  letter-spacing: 0.5rpx;
}

.section-count {
  font-size: 24rpx;
  color: #8e8e93;
}

/* ======== Segmented Control（自提/配送） ======== */
.segment-control {
  display: flex;
  background-color: #e5e5ea;
  border-radius: 24rpx;
  padding: 6rpx;
  gap: 0;
}

.segment {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #8e8e93;
  transition: all 0.25s ease;
}

.segment--active {
  background-color: #ffffff;
  color: #111111;
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.segment-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ======== 卡片 ======== */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ======== 列表 Cell ======== */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 88rpx;
}

.cell--link {
  cursor: pointer;
}

.cell-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cell-main--col {
  flex-direction: column;
}

.cell-label {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 4rpx;
}

.cell-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.cell-desc {
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.4;
}

.cell-value {
  font-size: 30rpx;
  font-weight: 500;
  color: #111111;
}

.cell-value--placeholder {
  color: #c7c7cc;
}

.cell-badge {
  display: inline-block;
  margin-left: 12rpx;
  padding: 4rpx 14rpx;
  background-color: #111111;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 10rpx;
}

.cell-chevron {
  font-size: 36rpx;
  color: #c7c7cc;
  margin-left: 16rpx;
  font-weight: 300;
}

.cell-divider {
  height: 1rpx;
  background-color: #f2f2f7;
  margin-left: 32rpx;
}

.cell-options {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
}

.option-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ======== 商品卡片 ======== */
.product-item {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
}

.product-item + .product-item {
  border-top: 1rpx solid #f2f2f7;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #f7f7f8;
}

.product-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-spec {
  font-size: 24rpx;
  color: #8e8e93;
}

.product-extra {
  font-size: 22rpx;
  color: #c7c7cc;
}

.product-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 4rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.product-qty {
  font-size: 26rpx;
  color: #8e8e93;
}

/* ======== 费用明细 ======== */
.fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.fee-row--link {
  cursor: pointer;
}

.fee-label-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fee-label {
  font-size: 28rpx;
  color: #333333;
}

.fee-tag {
  font-size: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #c9a227, #e8c050);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.fee-count {
  font-size: 22rpx;
  color: #ff3b30;
  background-color: #fff0f0;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}

.fee-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.fee-value--discount {
  color: #ff3b30;
}

.fee-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.fee-deduct {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff3b30;
}

.fee-remove {
  font-size: 36rpx;
  color: #8e8e93;
  margin-left: 16rpx;
  padding: 0 8rpx;
}

.fee-action {
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
}

.fee-placeholder {
  font-size: 26rpx;
  color: #c7c7cc;
}

.fee-chevron {
  font-size: 32rpx;
  color: #c7c7cc;
  margin-left: 4rpx;
}

.fee-divider {
  height: 1rpx;
  background-color: #f2f2f7;
  margin-left: 32rpx;
}

/* ======== 底部栏 ======== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  gap: 24rpx;
}

.bottom-left {
  flex: 1;
  min-width: 0;
}

.bottom-label {
  font-size: 26rpx;
  color: #8e8e93;
  margin-right: 8rpx;
}

.bottom-price {
  display: inline-flex;
  align-items: baseline;
}

.bottom-currency {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-right: 2rpx;
}

.bottom-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
  letter-spacing: -1rpx;
}

.bottom-note {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
  margin-top: 4rpx;
}

.bottom-btn {
  flex-shrink: 0;
  min-width: 240rpx;
  height: 88rpx;
  background-color: #111111;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

/* ======== 弹窗通用 ======== */
.modal-sheet {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-sheet--bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  border-radius: 28rpx 28rpx 0 0;
  max-height: 75vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111111;
}

.modal-close {
  font-size: 48rpx;
  color: #8e8e93;
  font-weight: 300;
  line-height: 1;
}

.modal-body {
  max-height: 60vh;
  padding: 16rpx 0;
}

.modal-empty {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #8e8e93;
}

.modal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.modal-item-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #111111;
}

.modal-edit-icon {
  width: 36rpx;
  height: 36rpx;
}

.modal-check {
  width: 36rpx;
  height: 36rpx;
}

.modal-footer {
  padding: 24rpx 36rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid #f2f2f7;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background-color: #111111;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ======== 代金券卡片 ======== */
.voucher-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #fffbf5, #fff8ee);
  border: 1.5rpx solid rgba(201, 162, 39, 0.3);
  border-radius: 20rpx;
  display: flex;
  gap: 24rpx;
}

.voucher-card--selected {
  border-color: #c9a227;
  background: linear-gradient(135deg, #fff8e8, #fff3d9);
}

.voucher-left {
  width: 140rpx;
  flex-shrink: 0;
  border-right: 2rpx dashed rgba(201, 162, 39, 0.5);
  padding-right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.voucher-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #c9a227;
  letter-spacing: -1rpx;
}

.voucher-min {
  font-size: 20rpx;
  color: #8e8e93;
}

.voucher-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.voucher-desc {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.voucher-expire {
  font-size: 22rpx;
  color: #8e8e93;
}

/* ======== 地址卡片 ======== */
.address-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-radius: 20rpx;
  background-color: #fafafa;
}

.address-card--default {
  background-color: #f5f5f7;
}

.address-check {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.address-info {
  flex: 1;
  min-width: 0;
}

.address-detail {
  font-size: 30rpx;
  font-weight: 500;
  color: #111111;
  line-height: 1.5;
  display: block;
}

.address-meta {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8e8e93;
}

.address-name,
.address-phone {
  margin-right: 16rpx;
}

.address-default {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #34c759;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
}

.address-edit {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

/* ======== 时间选择器 ======== */
.time-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.picker-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  max-height: 75vh;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111111;
}

.picker-close {
  font-size: 48rpx;
  color: #8e8e93;
  font-weight: 300;
}

.picker-body {
  display: flex;
  height: 460rpx;
}

.date-list {
  width: 36%;
  background-color: #f7f7f8;
}

.date-item {
  padding: 28rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  transition: background 0.2s;
}

.date-item--active {
  background-color: #ffffff;
  font-weight: 600;
  color: #111111;
}

.date-week {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: 4rpx;
}

.date-day {
  font-size: 28rpx;
  color: inherit;
}

.time-list {
  flex: 1;
}

.time-item {
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f2f2f7;
  font-size: 28rpx;
  color: #333333;
}

.time-item--active {
  font-weight: 600;
  color: #111111;
  background-color: #fafafa;
}

.picker-footer {
  padding: 24rpx 36rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f2f2f7;
}

.picker-btn {
  width: 100%;
  height: 88rpx;
  background-color: #111111;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ======== 地址弹窗遮罩 ======== */
.address-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}
