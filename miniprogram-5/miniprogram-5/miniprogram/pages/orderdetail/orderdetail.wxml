<!--pages/orderdetail/orderdetail.wxml - iOS 风格 -->
<scroll-view class="page-scroll" scroll-y wx:if="{{orderDetail && orderDetail.customerInfo}}">
  <view class="page-content">

    <!-- 取件方式：只读展示 -->
    <view class="section">
      <view class="card">
        <view class="segment-readonly">
          <view class="segment {{orderDetail.customerInfo.deliveryMethod === 0 ? 'segment--active' : ''}}">
            <image wx:if="{{orderDetail.customerInfo.deliveryMethod === 0}}" src="cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/定位.png" mode="widthFix" class="segment-icon" />
            <text>自提</text>
          </view>
          <view class="segment {{orderDetail.customerInfo.deliveryMethod === 1 ? 'segment--active' : ''}}">
            <image wx:if="{{orderDetail.customerInfo.deliveryMethod === 1}}" src="cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/电动车.png" mode="widthFix" class="segment-icon" />
            <text>配送</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 自提详情 -->
    <view class="section" wx:if="{{orderDetail.customerInfo.deliveryMethod === 0}}">
      <view class="card">
        <view class="cell">
          <view class="cell-main">
            <text class="cell-title">Oli Cake</text>
            <text class="cell-desc">深圳市南山区奥莉屿你烘焙店</text>
          </view>
        </view>
        <view class="cell-divider"></view>
        <view class="cell">
          <view class="cell-main">
            <text class="cell-label">提货人</text>
            <text class="cell-value">{{orderDetail.customerInfo.selectedConsignee.name}} {{orderDetail.customerInfo.selectedConsignee.code}}</text>
          </view>
        </view>
        <view class="cell-divider"></view>
        <view class="cell">
          <view class="cell-main">
            <text class="cell-label">提货时间</text>
            <text class="cell-value">{{orderDetail.customerInfo.selectedDateTime}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 配送详情 -->
    <view class="section" wx:if="{{orderDetail.customerInfo.deliveryMethod === 1}}">
      <view class="card">
        <view class="cell">
          <view class="cell-main">
            <text class="cell-desc">广东省深圳市</text>
            <text class="cell-badge">默认</text>
          </view>
        </view>
        <view class="cell-divider"></view>
        <view class="cell">
          <view class="cell-main cell-main--col">
            <text class="cell-value">{{orderDetail.customerInfo.selectedAddress.detail}}{{orderDetail.customerInfo.selectedAddress.region}}</text>
            <text class="cell-desc">{{orderDetail.customerInfo.selectedAddress.name}} {{orderDetail.customerInfo.selectedAddress.phone}}</text>
          </view>
        </view>
        <view class="cell-divider"></view>
        <view class="cell">
          <view class="cell-main">
            <text class="cell-label">配送方式</text>
          </view>
          <view class="cell-options">
            <view class="option-item">
              <image class="option-icon" src="{{orderDetail.customerInfo.deliveryMethod2 == 10 ? 'cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/chenggong.png' : 'cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/weixuanzhong.png'}}" mode="widthFix" />
              <text>跑腿到家</text>
            </view>
            <view class="option-item">
              <image class="option-icon" src="{{orderDetail.customerInfo.deliveryMethod2 == 11 ? 'cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/chenggong.png' : 'cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/weixuanzhong.png'}}" mode="widthFix" />
              <text>顺风车</text>
            </view>
          </view>
        </view>
        <view class="cell-divider"></view>
        <view class="cell">
          <view class="cell-main">
            <text class="cell-label">送达时间</text>
            <text class="cell-value">{{orderDetail.customerInfo.selectedDateTime}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">商品明细</text>
        <text class="section-count">共{{orderDetail.productInfo.length}}件</text>
      </view>
      <view class="card">
        <view class="product-item" wx:for="{{orderDetail.productInfo}}" wx:key="name">
          <image class="product-img" src="{{item.cover}}" mode="aspectFill" />
          <view class="product-body">
            <text class="product-title">{{item.title}}</text>
            <text class="product-spec">{{item.sizechoose}} · {{item.tastechoose}} · {{item.bagchoose}}</text>
            <text class="product-extra" wx:if="{{item.phone || item.message}}">{{item.phone}}{{item.message ? '；' + item.message : ''}}</text>
            <view class="product-row">
              <text class="product-price">¥{{item.Price}}</text>
              <text class="product-qty">×{{item.total}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 费用明细 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">费用明细</text>
      </view>
      <view class="card">
        <view class="fee-row">
          <text class="fee-label">订单总价</text>
          <text class="fee-value">¥{{totalFee}}</text>
        </view>
        <view class="fee-divider"></view>
        <view class="fee-row">
          <text class="fee-label">配送费</text>
          <text class="fee-value">¥{{orderDetail.customerInfo.deliveryfee}}</text>
        </view>
        <view class="fee-divider"></view>
        <view class="fee-row">
          <text class="fee-label">订单编号</text>
          <text class="fee-mono">{{orderDetail.orderNo}}</text>
        </view>
        <view class="fee-divider"></view>
        <view class="fee-row">
          <text class="fee-label">交易单号</text>
          <text class="fee-mono">{{orderDetail.wechatOrderNo}}</text>
        </view>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 加载中 -->
<view class="loading-wrap" wx:if="{{!orderDetail || !orderDetail.customerInfo}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 底部栏 -->
<view class="bottom-bar" wx:if="{{orderDetail && orderDetail.customerInfo}}">
  <view class="bottom-inner">
    <view class="bottom-btn bottom-btn--outline" bindtap="cancelOrder">取消订单</view>
  </view>
</view>
