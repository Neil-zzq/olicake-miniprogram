/* pages/orderdetail/orderdetail.wxss - iOS 原生风格 */

page {
  background-color: #f8f0ce;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
}

.page-scroll {
  height: calc(100vh - 120rpx);
}

.page-content {
  padding: 24rpx 28rpx 140rpx;
  min-height: 100%;
}

/* ======== 分组 ======== */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8e8e93;
  letter-spacing: 0.5rpx;
}

.section-count {
  font-size: 24rpx;
  color: #8e8e93;
}

/* ======== 卡片 ======== */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ======== 只读 Segment ======== */
.segment-readonly {
  display: flex;
  padding: 6rpx;
  background-color: #e5e5ea;
  border-radius: 24rpx;
  margin: 24rpx;
  gap: 0;
}

.segment-readonly .segment {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #8e8e93;
}

.segment-readonly .segment--active {
  background-color: #ffffff;
  color: #111111;
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.segment-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ======== Cell ======== */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 88rpx;
}

.cell-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cell-main--col {
  flex-direction: column;
}

.cell-label {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 4rpx;
}

.cell-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.cell-desc {
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.4;
}

.cell-value {
  font-size: 30rpx;
  font-weight: 500;
  color: #111111;
}

.cell-badge {
  display: inline-block;
  margin-left: 12rpx;
  padding: 4rpx 14rpx;
  background-color: #111111;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 10rpx;
}

.cell-divider {
  height: 1rpx;
  background-color: #f2f2f7;
  margin-left: 32rpx;
}

.cell-options {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
}

.option-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ======== 商品卡片 ======== */
.product-item {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
}

.product-item + .product-item {
  border-top: 1rpx solid #f2f2f7;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #f7f7f8;
}

.product-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-spec {
  font-size: 24rpx;
  color: #8e8e93;
}

.product-extra {
  font-size: 22rpx;
  color: #c7c7cc;
}

.product-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 4rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.product-qty {
  font-size: 26rpx;
  color: #8e8e93;
}

/* ======== 费用明细 ======== */
.fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.fee-label {
  font-size: 28rpx;
  color: #333333;
}

.fee-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.fee-mono {
  font-size: 24rpx;
  color: #8e8e93;
  font-family: "SF Mono", "Menlo", monospace;
}

.fee-divider {
  height: 1rpx;
  background-color: #f2f2f7;
  margin-left: 32rpx;
}

/* ======== 加载 ======== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #8e8e93;
}

/* ======== 底部栏 ======== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.bottom-inner {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 28rpx;
}

.bottom-btn {
  min-width: 200rpx;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-btn--outline {
  background-color: transparent;
  color: #8e8e93;
  border: 2rpx solid #e5e5ea;
}
