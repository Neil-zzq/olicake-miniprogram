/* pages/shopping-cart/shopping-cart.wxss */

page {
  width: 100%;
  height: 100%;
  background-color: #f5f4f2;
}

/* ======== Empty State ======== */

.empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f4f2;
}

.empty image {
  width: 260rpx;
  height: 260rpx;
  opacity: 0.3;
}

.emptyinfo {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #b0b0b0;
  letter-spacing: 2rpx;
}

/* ======== Scroll Area ======== */

.content {
  height: 100%;
}

.cart-list {
  padding: 24rpx 24rpx 0;
}

.bottom-placeholder {
  height: 180rpx;
}

/* ======== Card Container ======== */

.cart-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 22rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

/* ======== Item Row ======== */

.item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx 28rpx 0;
  transform: translateX(160rpx);
  margin-left: -160rpx;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  min-height: 220rpx;
}

.item.show {
  transform: translateX(0rpx);
}

/* ======== Square Checkbox ======== */

.checkbox {
  width: 42rpx;
  height: 42rpx;
  border: 2.5rpx solid #d0d0d5;
  border-radius: 8rpx;
  margin: 0 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

.checkbox.checked {
  background-color: #333232;
  border-color: #333232;
}

.check-mark {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1;
  margin-top: -2rpx;
}

/* ======== Product Image ======== */

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  background-color: #f5f4f2;
}

/* ======== Detail Section ======== */

.detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 180rpx;
  padding-right: 22rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
}

.spec {
  font-size: 22rpx;
  color: #999999;
  background-color: #f8f7f5;
  border-radius: 8rpx;
  padding: 8rpx 14rpx;
  line-height: 1.5;
}

.sub-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ======== Quantity Selector ======== */

.selector {
  display: flex;
  align-items: center;
  border: 1.5rpx solid #ebebeb;
  border-radius: 10rpx;
  overflow: hidden;
}

.sel-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333232;
  background-color: #f8f7f5;
}

.num {
  width: 58rpx;
  height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1a1a1a;
  background-color: #ffffff;
}

/* ======== Swipe Delete ======== */

.delete {
  width: 160rpx;
  flex-shrink: 0;
  background-color: #ff3b30;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  transform: translateX(160rpx);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.delete.show {
  transform: translateX(0rpx);
}

/* ======== Fixed Bottom Bar ======== */

.bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx;
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  z-index: 999;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all .checkbox {
  margin-left: 0;
  margin-right: 14rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.right-section {
  display: flex;
  align-items: center;
}

.total-area {
  display: flex;
  align-items: baseline;
  margin-right: 22rpx;
}

.total-label {
  font-size: 24rpx;
  color: #999999;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.checkout-button {
  background-color: #333232;
  color: #ffffff;
  height: 82rpx;
  padding: 0 40rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  letter-spacing: 1rpx;
}
