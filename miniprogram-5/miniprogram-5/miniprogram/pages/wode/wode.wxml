<!--pages/wode/wode.wxml-->
<view class="page-ios">
  <view class="ios-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="ios-nav__row" style="height: {{navBarContentHeight}}px;">
      <text class="nav-title">我的</text>
    </view>
  </view>
  <view class="nav-spacer" style="height: {{navBarHeight}}px;"></view>

  <!-- 个人信息卡 -->
  <view class="card profile-card" bindtap="onLoginTap">
    <image class="avatar" src="{{getUserInfoSuccess ? avatarUrl : defaultAvatarUrl}}" mode="aspectFill" />
    <view class="profile-main">
      <text class="profile-name">{{getUserInfoSuccess ? nickName : '请登录'}}</text>
      <text class="profile-sub">{{getUserInfoSuccess ? '欢迎回来' : '登录后查看订单、地址与个人信息'}}</text>
    </view>
    <text class="chevron">›</text>
  </view>

  <!-- 已注册：5 种会员卡可滑动 -->
  <view class="vip-swiper-wrap" wx:if="{{getUserInfoSuccess && usertype && tierList.length > 0}}">
    <swiper class="vip-swiper" circular indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" autoplay="{{false}}">
      <swiper-item wx:for="{{tierList}}" wx:key="key">
        <view class="card vip-card vip-{{item.key}} {{item.isUnlocked ? '' : 'vip-locked'}}">
          <view class="vip-header">
            <view class="vip-title-row">
              <text class="vip-tier-name">{{item.name}}</text>
              <text class="vip-discount-badge">{{item.discountLabel}}</text>
            </view>
            <text class="vip-discount-hint">会员专属折扣</text>
          </view>
          <view class="vip-divider"></view>
          <view class="vip-locked-mask" wx:if="{{item.isUnlocked}}">
            <text class="vip-locked-text">已解锁</text>
            <text class="vip-locked-hint" wx:if="{{item.nextThreshold}}">您已累计消费 ¥{{cumulativeSpending}}</text>
          </view>
          <view class="vip-locked-mask" wx:else>
            <text class="vip-locked-text">未解锁</text>
            <text class="vip-locked-hint" wx:if="{{item.nextThreshold}}">累计消费 ¥{{item.nextThreshold}} 解锁</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 已登录未注册：引导注册卡（样式与会员卡一致） -->
  <view class="card vip-card vip-default vip-register-card" wx:elif="{{getUserInfoSuccess && !usertype}}">
    <view class="vip-header">
      <view class="vip-title-row">
        <text class="vip-tier-name vip-default-name">注册会员</text>
        <text class="vip-discount-badge vip-default-badge">--折</text>
      </view>
      <text class="vip-discount-hint vip-default-hint">注册即送 20 元代金券，享专属折扣</text>
    </view>
    <view class="vip-divider"></view>
    <view class="vip-footer">
      <view class="vip-upgrade-row">
        <text class="vip-upgrade-text vip-register-cta" bindtap="navigateToRegister">点击注册，解锁会员等级 ›</text>
      </view>
    </view>
  </view>

  <!-- 未登录：占位预览 -->
  <view class="card vip-card vip-default vip-register-card" wx:else>
    <view class="vip-header">
      <view class="vip-title-row">
        <text class="vip-tier-name vip-default-name">注册会员</text>
        <text class="vip-discount-badge vip-default-badge">--折</text>
      </view>
      <text class="vip-discount-hint vip-default-hint">登录后查看您的会员等级</text>
    </view>
    <view class="vip-divider"></view>
    <view class="vip-footer">
      <view class="vip-upgrade-row">
        <text class="vip-upgrade-text">登录后即可查看会员权益</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="card group">
    <view class="cell" bindtap="navigatorToOrdercenter">
      <text class="cell-title">订单中心</text>
      <text class="cell-chevron">›</text>
    </view>
    <view class="cell" bindtap="navigatorToFavorites">
      <text class="cell-title">我的收藏</text>
      <text class="cell-chevron">›</text>
    </view> 
    <view class="cell-divider"></view>
    <view class="cell" bindtap="navigatorToAddAddress">
      <text class="cell-title">收货地址</text>
      <text class="cell-chevron">›</text>
    </view>
    <view class="cell-divider"></view>
    <view class="cell" bindtap="navigatorToCustomerInfo">
      <text class="cell-title">个人信息</text>
      <text class="cell-chevron">›</text>
    </view>
    <view class="cell-divider"></view>
    <view class="cell" bindtap="navigatorToAccountSet">
      <text class="cell-title">账号设置</text>
      <text class="cell-chevron">›</text>
    </view>
  </view>
</view>
