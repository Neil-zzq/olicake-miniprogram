<!--pages/wode/wode.wxml-->
<view class="title">
  <view class="userinfo1" bind:tap="getUserInfo" wx:if="{{getUserInfoSuccess}}">
    <image src="{{avatarUrl}}" mode="widthFix" class="user-avatar" />
    <view class="usernametel">
      <text class="username">{{nickName}}</text>
    </view>
  </view>
  <view class="userinfo1" bind:tap="getUserInfo" wx:else >
    <image src="cloud://cloud1-0gggau3xd319b71f.636c-cloud1-0gggau3xd319b71f-1317945786/其他/用户头像.png" mode="widthFix" class="user-avatar" />
    <view class="usernametel">
      <text class="username">点击获取用户信息</text>
    </view>
  </view>
  

</view>

<view class="card">
  <view class="cardtitle">
    <view class="cardtitletext">注册会员</view>
    <image class="QRCode" src="../../img/二维码.png" mode="widthFix" />
  </view>
  <view class="underline"></view>
  <view class="cardbottom">
    <view>再消费1000.00元升级</view>
    <view>
      <image class="level" src="../../img/401位置.png" mode="widthFix" />
      <text>当前等级</text>
    </view>
  </view>
</view>
<view class="bottom">
  <view class="bottom-card" bind:tap="navigatorToOrdercenter">
    <text>订单中心</text>
    <text class="jiantou"> > </text>
  </view>
  <view class="bottom-card" bind:tap="navigatorToAdd-address">
    <text>收货地址</text>
    <text class="jiantou"> > </text>
  </view>
  <view class="bottom-card" bind:tap="navigatorToCustomerInfo">
    <text>个人信息</text>
    <text class="jiantou"> > </text>
  </view>
  <view class="bottom-card" bind:tap="navigatorToAccountSet">
    <text>账号设置</text>
    <text class="jiantou"> > </text>
  </view>
</view>