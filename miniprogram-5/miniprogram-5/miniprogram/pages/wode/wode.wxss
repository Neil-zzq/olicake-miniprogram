/* pages/wode/wode.wxss */
page {
  width: 100%;
  min-height: 100%;
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
    "Helvetica Neue", sans-serif;
}

.page-ios {
  min-height: 100%;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
}

/* iOS 风格导航栏 */
.ios-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: rgba(245, 245, 247, 0.96);
}

.ios-nav__row {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 750;
  color: #111111;
}

.nav-spacer {
  width: 100%;
}

/* 通用卡片质感 */
.card {
  background-color: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 个人信息卡 */
.profile-card {
  margin-top: 18rpx;
  padding: 22rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  background-color: #f2f2f7;
  flex: 0 0 auto;
}

.profile-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 750;
  color: #111111;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.profile-sub {
  font-size: 24rpx;
  color: #8e8e93;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.chevron {
  font-size: 40rpx;
  color: #c7c7cc;
}

/* 会员卡 */
.vip-card {
  margin-top: 18rpx;
  padding: 22rpx;
}

.vip-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-title {
  font-size: 30rpx;
  font-weight: 750;
  color: #111111;
}

.vip-qr {
  width: 44rpx;
  height: 44rpx;
}

.vip-divider {
  height: 2rpx;
  background-color: #f2f2f7;
  margin: 18rpx 0;
}

.vip-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-desc {
  font-size: 24rpx;
  color: #8e8e93;
}

.vip-level {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #111111;
}

.vip-level-icon {
  width: 28rpx;
  height: 28rpx;
}

.vip-level-text {
  font-size: 24rpx;
  font-weight: 650;
}

/* 分组列表 */
.group {
  margin-top: 18rpx;
}

.cell {
  padding: 22rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cell-title {
  font-size: 28rpx;
  font-weight: 650;
  color: #111111;
}

.cell-chevron {
  font-size: 40rpx;
  color: #c7c7cc;
}

.cell-divider {
  height: 2rpx;
  background-color: #f2f2f7;
  margin-left: 22rpx;
}