/* pages/wode/wode.wxss */
page {
  width: 100%;
  min-height: 100%;
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
}

.page-ios {
  min-height: 100%;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
}

/* iOS 风格导航栏 */
.ios-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background-color: rgba(245, 245, 247, 0.96);
}

.ios-nav__row {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 750;
  color: #111111;
}

.nav-spacer { width: 100%; }

/* 通用卡片 */
.card {
  background-color: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 个人信息卡 */
.profile-card {
  margin-top: 18rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  background-color: #f2f2f7;
  flex: 0 0 auto;
}

.profile-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 750;
  color: #111111;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.profile-sub {
  font-size: 24rpx;
  color: #8e8e93;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.chevron {
  font-size: 40rpx;
  color: #c7c7cc;
}

/* ======== 会员卡通用结构 ======== */
.vip-card {
  margin-top: 18rpx;
  padding: 26rpx 26rpx 22rpx;
}

.vip-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vip-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-tier-name {
  font-size: 34rpx;
  font-weight: 750;
}

.vip-discount-badge {
  font-size: 26rpx;
  font-weight: 700;
  background-color: rgba(255, 255, 255, 0.25);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.vip-discount-hint {
  font-size: 22rpx;
  opacity: 0.75;
}

.vip-divider {
  height: 1.5rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 18rpx 0;
}

.vip-footer {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vip-spending-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vip-spending-label {
  font-size: 24rpx;
  opacity: 0.75;
}

.vip-spending-value {
  font-size: 28rpx;
  font-weight: 700;
}

.vip-upgrade-row {
  display: flex;
}

.vip-upgrade-text {
  font-size: 22rpx;
  opacity: 0.8;
  background-color: rgba(0, 0, 0, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.vip-top-text {
  background-color: rgba(255, 255, 255, 0.2);
}

/* ======== 5 种等级卡配色 ======== */

/* 会员（暖灰） - 深色文字 */
.vip-generalMember {
  background: linear-gradient(135deg, #e8e4de, #ccc6bc);
}
.vip-generalMember .vip-tier-name,
.vip-generalMember .vip-discount-badge,
.vip-generalMember .vip-discount-hint,
.vip-generalMember .vip-spending-label,
.vip-generalMember .vip-spending-value,
.vip-generalMember .vip-upgrade-text {
  color: #3a3530;
}
.vip-generalMember .vip-divider { background-color: rgba(0, 0, 0, 0.1); }
.vip-generalMember .vip-discount-badge { background-color: rgba(0, 0, 0, 0.08); }

/* 白银 - 深色文字 */
.vip-silver {
  background: linear-gradient(135deg, #d8d8e0, #a8a8b8);
}
.vip-silver .vip-tier-name,
.vip-silver .vip-discount-badge,
.vip-silver .vip-discount-hint,
.vip-silver .vip-spending-label,
.vip-silver .vip-spending-value,
.vip-silver .vip-upgrade-text {
  color: #2a2a3a;
}
.vip-silver .vip-divider { background-color: rgba(0, 0, 0, 0.1); }
.vip-silver .vip-discount-badge { background-color: rgba(255, 255, 255, 0.35); }

/* 铂金 - 白色文字 */
.vip-platinum {
  background: linear-gradient(135deg, #7b5ea7, #c9a227);
}
.vip-platinum .vip-tier-name,
.vip-platinum .vip-discount-badge,
.vip-platinum .vip-discount-hint,
.vip-platinum .vip-spending-label,
.vip-platinum .vip-spending-value,
.vip-platinum .vip-upgrade-text {
  color: #ffffff;
}

/* 黑金 - 白色/金色文字 */
.vip-blackGold {
  background: linear-gradient(135deg, #1a1a1a, #3a3020);
}
.vip-blackGold .vip-tier-name {
  color: #c9a227;
}
.vip-blackGold .vip-discount-badge {
  color: #c9a227;
  background-color: rgba(201, 162, 39, 0.15);
}
.vip-blackGold .vip-discount-hint,
.vip-blackGold .vip-spending-label,
.vip-blackGold .vip-spending-value,
.vip-blackGold .vip-upgrade-text {
  color: rgba(255, 255, 255, 0.85);
}
.vip-blackGold .vip-divider { background-color: rgba(201, 162, 39, 0.3); }

/* 钻石 - 白色文字 + 蓝色光感 */
.vip-diamond {
  background: linear-gradient(135deg, #1a237e, #283593, #42a5f5);
}
.vip-diamond .vip-tier-name,
.vip-diamond .vip-discount-badge,
.vip-diamond .vip-discount-hint,
.vip-diamond .vip-spending-label,
.vip-diamond .vip-spending-value,
.vip-diamond .vip-upgrade-text {
  color: #ffffff;
}

/* ======== 会员卡 Swiper ======== */
.vip-swiper-wrap {
  margin-top: 18rpx;
  
  height: 300rpx;
}

.vip-swiper {
  height: 300rpx;
}

.vip-swiper .vip-card {
 
  height: 300rpx;
  padding: 22rpx 24rpx 18rpx;
}

/* 未解锁状态：半透明遮罩 + 白色文字 */
.vip-locked {
  position: relative;
}

.vip-locked .vip-header {
  opacity: 0.6;
}

.vip-locked .vip-divider {
  opacity: 0.5;
}

.vip-locked-mask {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  gap: 8rpx;
}

.vip-locked-text {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* 浅色卡（会员、白银）用深色字 */
.vip-generalMember.vip-locked .vip-locked-text,
.vip-silver.vip-locked .vip-locked-text {
  color: rgba(0, 0, 0, 0.5);
}

.vip-generalMember.vip-locked .vip-locked-hint,
.vip-silver.vip-locked .vip-locked-hint {
  color: rgba(0, 0, 0, 0.4);
}

/* 深色卡用浅色字 */
.vip-platinum.vip-locked .vip-locked-text,
.vip-blackGold.vip-locked .vip-locked-text,
.vip-diamond.vip-locked .vip-locked-text {
  color: rgba(255, 255, 255, 0.9);
}

.vip-platinum.vip-locked .vip-locked-hint,
.vip-blackGold.vip-locked .vip-locked-hint,
.vip-diamond.vip-locked .vip-locked-hint {
  color: rgba(255, 255, 255, 0.7);
}

/* 默认（未注册） */
.vip-default {
  background: linear-gradient(135deg, #f8f7f5, #ece7df);
}
.vip-default-name { color: #1a1a1a !important; }
.vip-default-hint { color: #666 !important; opacity: 1 !important; }
.vip-register-link {
  font-size: 26rpx;
  font-weight: 600;
  color: #c9a227;
}
.vip-default .vip-divider { background-color: rgba(0, 0, 0, 0.08); }

/* 未注册等级预览 */
.vip-tiers-row {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.mini-badge {
  flex: 1;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  color: #ffffff;
}

.mini-member   { background: linear-gradient(135deg, #c8c8c0, #a0a098); color: #333; }
.mini-silver   { background: linear-gradient(135deg, #b8b8c0, #888898); }
.mini-platinum { background: linear-gradient(135deg, #9b7fd4, #c9a227); }
.mini-blackgold { background: linear-gradient(135deg, #2a2a2a, #c9a227); }
.mini-diamond  { background: linear-gradient(135deg, #1a237e, #42a5f5); }

/* 分组列表 */
.group { margin-top: 18rpx; }

.cell {
  padding: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cell-title {
  font-size: 28rpx;
  font-weight: 650;
  color: #111111;
}

.cell-chevron {
  font-size: 40rpx;
  color: #c7c7cc;
}

.cell-divider {
  height: 2rpx;
  background-color: #f2f2f7;
  margin-left: 22rpx;
}
